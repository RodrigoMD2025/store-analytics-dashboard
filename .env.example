# -------------------------------------------------------
# Store Analytics Dashboard - Environment Variables
#
# NEVER commit this file with real values!
# Copy this file as .env and fill in your own credentials.
# -------------------------------------------------------

# === SUPABASE (Frontend) ===
# New model (Publishable Key - preferred)
VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Legacy model fallback (keep until fully migrated)
# VITE_SUPABASE_ANON_KEY=your-legacy-anon-key

# === TELEGRAM BOT (Backend) ===
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
AUTHORIZED_CHAT_ID=your-telegram-chat-id
ADMIN_CHAT_ID=your-admin-chat-id

# === GITHUB (Backend - if needed) ===
GITHUB_TOKEN=your-github-token
